#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -n "${LANGSTITCH_SPRING_AI_JAR:-}" ]]; then
  JAR="$LANGSTITCH_SPRING_AI_JAR"
else
  JAR="$(ls -1 "$ROOT"/target/langstitch-spring-ai-*-all.jar 2>/dev/null | tail -n 1 || true)"
fi
if [[ -z "${JAR:-}" || ! -f "$JAR" ]]; then
  echo "error: fat jar not found under target/*-all.jar" >&2
  echo "Build with: mvn -q package" >&2
  echo "Or set LANGSTITCH_SPRING_AI_JAR to the *-all.jar path." >&2
  exit 1
fi
exec java -jar "$JAR" "$@"
